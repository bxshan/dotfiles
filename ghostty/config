# Ghostty config — Linux equivalent of the macOS alacritty.toml in this repo.
# Docs: https://ghostty.org/docs/config

# Font (same Nerd Font + size as the alacritty config)
font-family = Comic Mono
font-family = FiraCode Nerd Font
font-size = 20

# Chinese: use the monospace CJK face so glyphs stay aligned in the cell grid.
# Covers CJK punctuation, Ext-A, unified ideographs, compatibility, fullwidth forms.
font-codepoint-map = U+3000-U+303F,U+3400-U+4DBF,U+4E00-U+9FFF,U+F900-U+FAFF,U+FF00-U+FFEF=Noto Sans Mono CJK SC

# Gruvbox dark, matching the alacritty gruvbox_dark theme import
theme = Gruvbox Dark

# Window
background-opacity = 1.0
window-padding-x = 3
window-padding-y = 3
window-padding-balance = true
window-width = 100
window-height = 40
title = bxshan

# Cursor: solid block, no blink
cursor-style = block
cursor-style-blink = false

# Mouse
mouse-hide-while-typing = true
mouse-scroll-multiplier = 1.5

# Generous scrollback (alacritty used 100000 lines)
scrollback-limit = 100000000
